{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "review": {
      "description": "コードレビュー、仕様確認",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "docs": {
      "description": "ドキュメント設計・議論",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "debug": {
      "description": "エラー解析、ログ調査",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    }
  }
}
